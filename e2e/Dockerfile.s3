FROM rust:1.95-bookworm@sha256:6258907abe69656e41cd992e0b705cdcfabcbbe3db374f92ed2d47121282d4a1 AS build

WORKDIR /src
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY adapters ./adapters
COPY bins ./bins
COPY crates ./crates
COPY e2e ./e2e
COPY migrations ./migrations
COPY xtask ./xtask
RUN cargo build --locked --manifest-path e2e/Cargo.toml --bin s3-server --release

FROM debian:bookworm-slim@sha256:7b140f374b289a7c2befc338f42ebe6441b7ea838a042bbd5acbfca6ec875818

COPY --from=build /src/e2e/target/release/s3-server /usr/local/bin/s3-server
USER 65532:65532
ENTRYPOINT ["/usr/local/bin/s3-server"]
